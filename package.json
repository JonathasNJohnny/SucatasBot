{
  "name": "sucatasbot",
  "version": "2.7.4",
  "description": "Controle Gacha e Bot para Twitch",
  "main": "main.js",
  "productName": "SucatasBot",
  "build": {
    "appId": "com.sucatas.bot",
    "productName": "Sucatas Bot",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "cscLink": "sucatas-bot-cert.pfx",
      "cscKeyPassword": "sucatasbot123"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "JonathasNJohnny",
        "repo": "SucatasBot",
        "private": false,
        "releaseType": "release"
      }
    ]
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dev": "node server.js --open",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "publish:win": "electron-builder --win --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
